# Copy this file to .env and fill in real values. NEVER commit the real .env.
GROQ_API_KEY=your_groq_api_key
MONGO_URI=mongodb+srv://user:password@host/   # mongodb:// or mongodb+srv:// (raw password is fine; it is URL-encoded safely)
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=your_index_name
PINECONE_ENVIRONMENT=your_pinecone_region

# Optional: shared password gating the Streamlit app. If unset, the app runs without auth.
APP_PASSWORD=

# Optional: set to DEBUG for verbose local logging (logs patient text — do NOT use in production).
LOG_LEVEL=INFO
